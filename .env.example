# ============================================================
# Smart Telegram Moderator AI — пример конфигурации.
# Скопируйте в .env и заполните реальными значениями.
# ============================================================

# --- Общее ---
APP_NAME=smart-telegram-moderator
ENVIRONMENT=development            # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=false                     # true — логи в формате JSON

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:CHANGE_ME
TELEGRAM_API_TIMEOUT=30
TELEGRAM_MAX_RETRIES=5

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=moderator
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=moderator
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- ML ---
ML_MODEL_PATH=models/toxicity.joblib
ML_TOXICITY_THRESHOLD=0.8
ML_SPAM_THRESHOLD=0.85

# --- Модерация (пороги) ---
MAX_WARNINGS=3                     # предупреждений до мута
MUTE_DURATION_MINUTES=60
FLOOD_MESSAGES=5                   # сообщений
FLOOD_INTERVAL_SECONDS=10          # за интервал

# --- API / Авторизация ---
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
